\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{bookstyle}[2026/04/21 Stable jlreq page style for LuaLaTeX book]

\RequirePackage{xcolor}
\RequirePackage{etoolbox}

\definecolor{BookText}{gray}{0.0}
\definecolor{BookAccent}{gray}{0.15}
\definecolor{BookLine}{gray}{0.50}

\AtBeginDocument{\color{BookText}}

\ModifyPageStyle{headings}{%
  nombre_position=top-fore-edge,%
  running_head_position=top-left,%
  odd_head_format={\textcolor{BookLine}{\underline{\makebox[\jlreqyokoheadlength]{\textcolor{BookAccent}{#1}}}}},%
  even_head_format={\textcolor{BookLine}{\underline{\makebox[\jlreqyokoheadlength]{\textcolor{BookAccent}{#1}}}}},%
  odd_foot_format={},%
  even_foot_format={}%
}

\ModifyPageStyle{plain}{%
  nombre_position=top-fore-edge,%
  odd_head_format={\makebox[\jlreqyokoheadlength][r]{\textcolor{BookAccent}{#1}}},%
  even_head_format={\makebox[\jlreqyokoheadlength][l]{\textcolor{BookAccent}{#1}}},%
  odd_foot_format={},%
  even_foot_format={}%
}

\pagestyle{headings}

\ModifyHeading{chapter}{%
  lines=12,%
  font={\Huge\sffamily\bfseries},%
  format={%
    \vspace*{0.5ex}%
    {\raggedright #1\par}%
    \vspace{1ex}%
    {\raggedright #2\par}%
    \vspace{1ex}%
    {\noindent\makebox[\linewidth][l]{\textcolor{BookLine}{\rule{\linewidth}{0.5pt}}}\par}%
    \vspace{0.5ex}%
  }%
}

\ModifyHeading{section}{%
  lines=3.5,%
  font={\LARGE\sffamily\bfseries},%
  label_format={\thesection},%
  format={\noindent#1\hspace{1em}#2}%
}

\ModifyHeading{subsection}{%
  lines=2.5,%
  font={\Large\sffamily\bfseries},%
  label_format={\thesubsection},%
  format={\noindent#1\hspace{1em}#2}%
}

\ModifyHeading{subsubsection}{%
  lines=1.5,%
  font={\large\sffamily\bfseries},%
  label_format={\thesubsubsection},%
  format={\noindent#1\hspace{1em}#2}%
}

\preto\chapter{\cleardoublepage}

\endinput
